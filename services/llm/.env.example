# ===========================================================================
# NovaBot LLM Backend — Environment Variables
# ===========================================================================

# --- Existing LLM config ---
HUGGINGFACE_API_KEY=
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
CHAT_LLM_DEFAULT_PROFILE=

# --- Mental Health Therapy Pipeline ---
# The pipeline cascades through providers: Groq -> Cerebras -> SambaNova -> Gemini
# You only need ONE provider to work, but adding more improves reliability.

# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Get a free key at https://cloud.cerebras.ai (Groq alternative, no region blocks)
CEREBRAS_API_KEY=

# Get a free key at https://cloud.sambanova.ai (another Groq alternative)
SAMBANOVA_API_KEY=

# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=

# Optional: override model choices
# GROQ_THERAPY_MODEL=llama-3.3-70b-versatile
# GROQ_GUARD_MODEL=llama-guard-3-8b
# GEMINI_THERAPY_MODEL=gemini-2.0-flash
# CEREBRAS_MODEL=llama-3.3-70b
# SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
