# Robot service environment variables
# Copy to .env and adjust as needed

ROBOT_SERVICE_HOST=0.0.0.0
ROBOT_SERVICE_PORT=9000

# Camera
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_INDEX=0

# Movement
DEFAULT_SPEED=30
MAX_SPEED=80
OBSTACLE_STOP_DISTANCE_MM=300

# Audio
TTS_LANG=en
TTS_TEMP_DIR=/tmp/novacare_tts
STT_LANG=en-US
STT_TIMEOUT=10
STT_PHRASE_TIMEOUT=5

# LiDAR
LIDAR_ENABLED=true

# Camera streaming (for live feed)
STREAM_WIDTH=320
STREAM_HEIGHT=240
STREAM_FPS=10
STREAM_JPEG_QUALITY=60
