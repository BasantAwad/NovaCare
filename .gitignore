# ---- Python ----
**/venv/
**/env/
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.pyo
**/*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so
.frontend-novacare.pem

# ---- Node.js / Next.js ----
**/node_modules/
**/.next/
**/*.tsbuildinfo
**/out/
next-env.d.ts
.pnp/
.pnp.js

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
=
# ---- Databases ----
*.db
*.sqlite3
instance/
mock_mysql.db

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Large Model Files ----
