services/asl-model/checkpoints/
services/asl-model/data/asl_alphabet_train/
services/asl-model/data/asl_alphabet_test/
services/asl-model/data/raw/
services/asl-model/data/processed/
services/asl-model/data/models/

# ---- Build & Cache ----
*.log
npm-debug.log*
package-lock.json
.webassets-cache
.vercel

# ---- Test & Scratch Files ----
database_testing/
# test_*.py  # Unlocked for robot scripts
*_test.py
final_db_test.py
export_db.py
setup_mock_db.py

# ---- Generated PDF Reports ----
*.pdf
!docs/**/*.pdf
